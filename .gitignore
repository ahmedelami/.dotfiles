# Ignore private GitHub auth tokens
.config/gh/hosts.yml

# Personal Secrets
.zsh_secrets
secrets.zsh
.env
*.key
*.pem

# App data (can include cookies/tokens and large debug dumps)
.config/slack-terminal/

# Zed local state (databases, conversations)
.config/zed/prompts/
.config/zed/conversations/

# History exports: allow the sanitized snapshot, but ignore any backups.
history/*.bak-*
.config/nvim/.toggleterm-zdotdir/
.config/nvim/.deps/
.config/nvim/temp.md
bin/__pycache__/
zsh/.zshrc.pre_ohmyzsh_removal_*
bin/codex-ghostty-proxy
bin/codex-ghostty-proxy.backup-*
codex-ghostty-proxy/target/
