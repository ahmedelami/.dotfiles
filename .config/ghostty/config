# Ghostty Configuration

# Theme: High Contrast Black on White
foreground = #000000
background = #ffffff
cursor-color = #000000
cursor-style = block
cursor-style-blink = false
# Keep shell integration for cwd inheritance/PATH, but don't let Ghostty
# replace the title with the running command.
shell-integration-features = no-cursor,no-sudo,no-title,no-ssh-env,no-ssh-terminfo,path
selection-background = #d6d6d6
selection-foreground = #000000

# ANSI palette: match SwiftTerm (UT7 side panel)
palette = 0=#000000
palette = 1=#c23621
palette = 2=#25bc24
palette = 3=#adad27
palette = 4=#492ee1
palette = 5=#d338d3
palette = 6=#33bbc8
palette = 7=#cbcccd
palette = 8=#818383
palette = 9=#fc391f
palette = 10=#31e722
palette = 11=#eaec23
palette = 12=#5833ff
palette = 13=#f935f8
palette = 14=#14f0f0
palette = 15=#e9ebeb

# Font
font-family = ""
font-family = Menlo
font-family = JetBrainsMono Nerd Font Mono
font-size = 11.875
font-thicken = true
font-thicken-strength = 0

# Shell
command = "direct:/bin/zsh -l"

# Keep the native shortcuts explicit so new tabs/windows always take Ghostty's
# built-in path even if upstream defaults shift between builds.
keybind = super+t=new_tab
keybind = super+n=new_window
# Forward Cmd+E into Neovim as CSI 19;3~ for the file tree binding.
keybind = super+e=csi:19;3~
# Forward Cmd+R into Neovim as CSI 28~ / F15 for the git review sidecar.
keybind = super+r=csi:28~
# Working directory
# Start new windows/tabs in the home directory instead of inheriting the
# focused surface's cwd or falling back to /.
working-directory = /Users/ahmedelamin
window-inherit-working-directory = false

# Window (macOS defaults: traffic lights + native tabs)
# Leave maximize off so AeroSpace can size Cmd+N windows into the tile tree
# instead of Ghostty asking macOS for a full-display frame first.
window-decoration = auto
macos-titlebar-style = transparent
maximize = false
# Ghostty 1.2 keeps recently closed terminals around for undo on macOS.
# Disable that retention so closed windows disappear immediately and
# AeroSpace can let the surviving window fill the space without the long
# nearly-invisible linger.
undo-timeout = 0
window-padding-y = 0

# Mouse
mouse-hide-while-typing = true

# Unfocused state (make inactive panes dimmer)
unfocused-split-opacity = 0.6

# Panes (Ghostty splits)
#
# Vim-style focus movement between Ghostty splits.
# Note: this overrides macOS Cmd+H (Hide) and Ghostty's default Cmd+K (Clear Screen).
#
# We bind both:
# - the produced character (layout-aware), and
# - the physical key (layout-agnostic).
keybind = super+h=goto_split:left
keybind = super+j=goto_split:down
keybind = super+k=goto_split:up
keybind = super+l=goto_split:right
keybind = super+key_h=goto_split:left
keybind = super+key_j=goto_split:down
keybind = super+key_k=goto_split:up
keybind = super+key_l=goto_split:right

# Vim-style split creation in a specific direction.
keybind = super+shift+h=new_split:left
keybind = super+shift+j=new_split:down
keybind = super+shift+k=new_split:up
keybind = super+shift+l=new_split:right
keybind = super+shift+key_h=new_split:left
keybind = super+shift+key_j=new_split:down
keybind = super+shift+key_k=new_split:up
keybind = super+shift+key_l=new_split:right

# Resize the focused split by pushing its boundary in the pressed direction.
# Leave plain Ctrl+H/J/K/L untouched; Ctrl+Shift is the custom coarse jump.
keybind = ctrl+shift+h=resize_split:left,50
keybind = ctrl+shift+j=resize_split:down,50
keybind = ctrl+shift+k=resize_split:up,50
keybind = ctrl+shift+l=resize_split:right,50
keybind = ctrl+shift+key_h=resize_split:left,50
keybind = ctrl+shift+key_j=resize_split:down,50
keybind = ctrl+shift+key_k=resize_split:up,50
keybind = ctrl+shift+key_l=resize_split:right,50
keybind = ctrl+shift+==equalize_splits

# Alternate bindings (Cmd+Opt) in case Cmd+Shift letter combos are grabbed by the OS/app.
keybind = super+alt+h=goto_split:left
keybind = super+alt+j=goto_split:down
keybind = super+alt+k=goto_split:up
keybind = super+alt+l=goto_split:right
keybind = super+alt+key_h=goto_split:left
keybind = super+alt+key_j=goto_split:down
keybind = super+alt+key_k=goto_split:up
keybind = super+alt+key_l=goto_split:right

keybind = super+alt+shift+h=new_split:left
keybind = super+alt+shift+j=new_split:down
keybind = super+alt+shift+k=new_split:up
keybind = super+alt+shift+l=new_split:right
keybind = super+alt+shift+key_h=new_split:left
keybind = super+alt+shift+key_j=new_split:down
keybind = super+alt+shift+key_k=new_split:up
keybind = super+alt+shift+key_l=new_split:right

# Preserve the default clear-screen behavior on a new key.
keybind = super+ctrl+k=clear_screen
