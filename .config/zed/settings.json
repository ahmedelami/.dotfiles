// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "show_edit_predictions": false,
  "terminal": {
    "dock": "bottom"
  },
  "context_servers": {
    "svelte-mcp": {
      "enabled": true,
      "settings": {},
    },
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Gruvbox Dark",
  },
  "agent_servers": {
    "local-claude-v2": {
      "type": "custom",
      "command": "/Users/ahmedelamin/zed-local-agent-poc/zed-local-claude.sh"
    },
    "local-gemini-v2": {
      "type": "custom",
      "command": "/Users/ahmedelamin/zed-local-agent-poc/zed-local-gemini.sh"
    },
    "local-codex-v2": {
      "type": "custom",
      "command": "/Users/ahmedelamin/zed-local-agent-poc/zed-local-codex.sh"
    }
  }
}
