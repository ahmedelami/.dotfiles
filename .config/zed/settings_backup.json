// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "context_servers": {
    "svelte-mcp": {
      "enabled": true,
      "settings": {},
    },
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Gruvbox Light",
    "dark": "Gruvbox Dark",
  },
  // TEMP: use trace wrapper while debugging; revert to zed-local-shim.py after stable.
  // NOTE: trace.log will contain raw prompts and JSON-RPC traffic.
  "agent_servers": {
    "local-claude-v2": {
      "command": "/Users/ahmedelamin/zed-local-agent-poc/zed-trace-wrapper.sh"
    }
  }
}
